# ═══════════════════════════════════════════════════════════════
# 🦅 EAGLE GYM — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/eagle_gym?schema=public"

# ── Authentication (NextAuth v5) ──────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="super-secret-key-replace-me"
NEXTAUTH_URL="http://localhost:3000"

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api"

# ── Email (Resend) ────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=""

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ── File Storage ──────────────────────────────────────────────
# For production: use an S3-compatible service
# STORAGE_BUCKET=""
# STORAGE_REGION=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""

# ── Redis (Upstash — optional, for rate limiting) ─────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""